# ===== Servidor =====
PORT=3001
NODE_ENV=development

# URL pública do frontend (usado em back_urls do Mercado Pago e nos links gerados)
FRONTEND_URL=http://localhost:5173

# URL pública do backend (usado pelo webhook do Mercado Pago).
# Em desenvolvimento use ngrok ou similar e coloque aqui a URL HTTPS pública.
BACKEND_PUBLIC_URL=https://SEU-TUNNEL.ngrok-free.app

# Token simples para proteger endpoints de admin (geração de slots).
# Envie no header: x-admin-token
ADMIN_TOKEN=troque-por-um-token-forte

# ===== Mercado Pago =====
# https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Segredo opcional usado para validar assinatura do webhook (x-signature)
MP_WEBHOOK_SECRET=troque-por-um-segredo-do-painel-mp

# ===== Firebase Admin =====
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Alternativa: cole o JSON em uma linha:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# ===== Google Calendar =====
# ID do calendário onde os eventos serão criados
# (pegue em: Google Calendar > Configurações do calendário > Integrar calendário > ID do calendário)
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo

# Credencial da Service Account do Google (com permissão no calendário acima).
GOOGLE_SERVICE_ACCOUNT_PATH=./googleServiceAccount.json
# Alternativa (uma linha):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# ===== Resend (e-mail de confirmação) =====
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Remetente verificado (use onboarding@resend.dev em dev, ou seu domínio verificado em prod)
RESEND_FROM_EMAIL=Escape Room <onboarding@resend.dev>
